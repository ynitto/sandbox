{
  "id": "chain-of-verification",
  "name": "Chain-of-Verification (CoVe)",
  "category": "verification-judging",
  "tier": "medium",
  "source": "CoVe (Dhuliawala et al., 2023)",
  "when_to_use": "草稿の主張を検証質問へ分解し、独立検証してから改稿し事実性を上げたいとき。",
  "signals": [
    "事実性を高めたい",
    "主張の裏取り"
  ],
  "team": {
    "roles": [
      {
        "id": "drafter",
        "role": "草稿を書き、検証質問を立て、証拠に基づき改稿する",
        "required": true,
        "approver": false
      },
      {
        "id": "checker",
        "role": "検証質問に草稿を見ずに答え、証拠を返す",
        "required": true,
        "approver": true,
        "collaborates_with": [
          "drafter"
        ]
      }
    ],
    "convergence": {
      "done_when": "reviewer-approved",
      "review_rounds": 2
    }
  },
  "feasibility": "partial",
  "feasibility_note": "検証質問の並列独立回答は checker の逐次確認で近似。"
}
