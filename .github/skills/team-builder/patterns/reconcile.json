{
  "id": "reconcile",
  "name": "ReConcile（円卓合意）",
  "category": "debate-consensus",
  "tier": "medium",
  "source": "ReConcile (Chen et al., 2024)",
  "when_to_use": "異質な複数エージェントが確信度付きで議論し合意に至りたいとき。",
  "signals": [
    "異質な視点の合議",
    "確信度で重み付け"
  ],
  "team": {
    "roles": [
      {
        "id": "member-a",
        "role": "確信度付きで見解を述べ議論する",
        "required": true,
        "approver": false
      },
      {
        "id": "member-b",
        "role": "別視点で議論する",
        "required": true,
        "approver": false,
        "collaborates_with": [
          "member-a"
        ]
      },
      {
        "id": "member-c",
        "role": "さらに別視点で議論する",
        "required": true,
        "approver": false,
        "collaborates_with": [
          "member-a"
        ]
      },
      {
        "id": "moderator",
        "role": "合意を取りまとめ承認する",
        "required": true,
        "approver": true
      }
    ],
    "convergence": {
      "done_when": "reviewer-approved",
      "quiescence_turns": 2
    }
  },
  "feasibility": "partial",
  "feasibility_note": "member は seats>1（G1）で増やせ、単純多数決は aggregate: majority（G2）で可能。確信度重み付き投票は未実装（G2 の重み付きモード追加待ち）で、moderator の裁定で近似する。"
}
