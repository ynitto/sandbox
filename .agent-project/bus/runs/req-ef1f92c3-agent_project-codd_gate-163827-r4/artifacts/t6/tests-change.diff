+    @contextlib.contextmanager
+    def _sibling(self, **modules):
+        """走査対象の sibling ディレクトリを差し替える。`__init__.py` の exec 合成により本体の
+        `__file__` は常に `agent_project/__init__.py` を指すので、そこを付け替えると
+        `Path(__file__).resolve().parent.parent` の走査対象だけが変わる。"""
+        with tempfile.TemporaryDirectory() as d:
+            d = Path(d)
+            (d / "agent_project").mkdir()
+            for name, src in modules.items():
+                (d / (name + ".py")).write_text(src, encoding="utf-8")
+            saved = (km.__file__, list(sys.path), set(sys.modules))
+            km.__file__ = str(d / "agent_project" / "__init__.py")
+            sys.path.insert(0, str(d))     # 明示指定の module は import 可能である前提
+            try:
+                yield d
+            finally:
+                km.__file__, sys.path[:] = saved[0], saved[1]
+                for name in set(sys.modules) - saved[2]:
