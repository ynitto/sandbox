diff --git a/tools/agent-project/agent_project/mr.py b/tools/agent-project/agent_project/mr.py
index c6ac2431..24354e13 100644
--- a/tools/agent-project/agent_project/mr.py
+++ b/tools/agent-project/agent_project/mr.py
@@ -400,6 +400,26 @@ def _settle_failure(cfg, task, vmsg, cycle, ev, reasons, location="local"):
                                     f"({task.retries}/{cfg.max_retries}) — {vmsg}")
 
 
+def _codd_gate_regression_ready(cmd: str) -> bool:
+    """regression_cmd が codd-gate 由来なら detect_status().usable のときだけ回帰ゲートを有効にする
+    （未導入環境で command-not-found（exit 127）を「回帰検知」と誤読しない no-op 縮退）。
+    codd-gate に依らない regression_cmd（`make -s smoke` 等）は従来どおり常に有効。"""
+    if "codd-gate" not in cmd:
+        return True
+    return detect_status().usable
+
+
+def _codd_gate_regression_env(cfg: "Config", task: "Task", venv: "dict | None") -> "dict | None":
+    """codd-gate 由来の regression_cmd が参照する `$KIRO_BASE_REV` を、venv 未注入（workspace 未指定
+    タスク等）のケースでも埋める。優先順位は codd_gate_base.resolve_base_rev のとおり（既存 venv の
+    値 > タスクの workspace base ブランチ > HEAD~1）。codd-gate 以外の regression_cmd には影響しない。"""
+    if "codd-gate" not in cfg.regression_cmd or (venv and venv.get("KIRO_BASE_REV")):
+        return venv
+    spec = _workspace_spec_for(cfg, task)
+    base_rev = resolve_base_rev(spec.get("base") if spec else None, env=venv or {})
+    return {**(venv or {}), "KIRO_BASE_REV": base_rev}
+
+
