     return load_repo_registry(cfg) or []
 
 
+def codd_gate_repo_args(cfg: "Config", ch: "Charter | None" = None) -> "tuple[Path, list[str]] | None":
+    """codd-gate へ渡す `--repos`/`--repo-dir` 引数を kiro-project の作業ディレクトリ情報
+    （repos.json の実際の設置場所・実効レジストリの repo_specs）から組み立てる。
+    レジストリが空なら None（codd-gate を呼ぶ材料が無い）。
+
+    `--repo-dir NAME=DIR` の DIR は、書込先（owns あり）の repo なら "."（verify/regression は
+    常に該当 repo のクローン直下を cwd にして走る規約——`_task_verify_cwd` と同じ前提）、
+    参照 repo（owns 無し）は `local`（手元クローンの絶対パス）が明示されている場合のみ含める
+    （不明な場所を推測しない）。"""
+    repos_path = repo_registry_path(cfg) or (cfg.backlog.parent / "repos.json")
+    specs = registry_specs(cfg, ch)
+    if not specs:
+        return None
+    repo_dirs = []
+    for s in specs:
+        name = s.get("name")
+        if not name:
+            continue
+        if s.get("owns"):
+            repo_dirs.append(f"{name}={s.get('local') or '.'}")
+        elif s.get("local"):
+            repo_dirs.append(f"{name}={s['local']}")
+    return repos_path, repo_dirs
+
+
