+class TestCoddGateRepoArgs(unittest.TestCase):
+    """codd-gate 差分ゲート用の `--repos`/`--repo-dir` 引数ビルダ（codd_gate_repo_args）。
+    repos.json のパスと repo-dir マッピングを kiro-project の作業ディレクトリ情報から組み立てる。"""
+
+    def test_codd_gate_self_hosted_single_workspace_repo(self):
+        with tempfile.TemporaryDirectory() as d:
+            d = Path(d)
+            cfg = cfg_for(d)
+            (d / "charter.md").write_text(
+                "# Charter: x\n## goal\ny\n## repos\n- sandbox = git@x:sandbox.git\n"
+                "  - desc: 本体\n  - base: main\n  - owns: **\n", encoding="utf-8")
+            ch = km.load_charter(cfg)
+            repos_path, repo_dirs = km.codd_gate_repo_args(cfg, ch)
+            self.assertEqual(repos_path, d / "repos.json")
+            self.assertEqual(repo_dirs, ["sandbox=."])       # verify は該当 repo 直下を cwd にする規約
+
+    def test_codd_gate_excludes_readonly_without_local_hint(self):
+        with tempfile.TemporaryDirectory() as d:
+            d = Path(d)
+            cfg = cfg_for(d)
+            (d / "charter.md").write_text(
+                "# Charter: x\n## goal\ny\n"
+                "## repos\n- app = git@x:app.git\n  - desc: 本体\n  - base: main\n  - owns: src/**\n"
+                "- ref = git@x:ref.git\n  - desc: 参照\n  - base: main\n", encoding="utf-8")
+            ch = km.load_charter(cfg)
+            repos_path, repo_dirs = km.codd_gate_repo_args(cfg, ch)
+            self.assertEqual(repo_dirs, ["app=."])           # readonly（owns 無し・local 無し）は含めない
+
+    def test_codd_gate_uses_local_hint_for_readonly_repo(self):
+        with tempfile.TemporaryDirectory() as d:
+            d = Path(d)
+            cfg = cfg_for(d)
+            (d / "repos.json").write_text(json.dumps(
+                {"app": {"url": "git@x:app.git", "desc": "本体", "base": "main", "owns": ["src/**"]},
+                 "ref": {"url": "git@x:ref.git", "desc": "参照", "base": "main",
+                         "local": "/abs/clone/ref"}}), encoding="utf-8")
+            ch = km.load_charter(cfg)
+            repos_path, repo_dirs = km.codd_gate_repo_args(cfg, ch)
+            self.assertEqual(set(repo_dirs), {"app=.", "ref=/abs/clone/ref"})
+
+    def test_codd_gate_no_registry_returns_none(self):
+        with tempfile.TemporaryDirectory() as d:
+            d = Path(d)
+            cfg = cfg_for(d)
+            self.assertIsNone(km.load_charter(cfg))
+            self.assertIsNone(km.codd_gate_repo_args(cfg, None))
+
+
