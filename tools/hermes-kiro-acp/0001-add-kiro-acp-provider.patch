index 0000000..12c6811
--- /dev/null
+++ b/plugins/model-providers/kiro-acp/__init__.py
@@ -0,0 +1,35 @@
+"""Kiro ACP provider profile.
+
+kiro-acp uses an external ACP subprocess (`kiro-cli acp`) — NOT the standard
+transport. The actual routing happens in agent_runtime_helpers.create_openai_client,
+which dispatches the ``acp://kiro`` base_url to KiroACPClient. This profile
+captures auth + endpoint metadata for the provider registry.
+"""
+
+from providers import register_provider
+from providers.base import ProviderProfile
+
+
+class KiroACPProfile(ProviderProfile):
+    """Kiro ACP — external process, no REST models endpoint."""
+
+    def fetch_models(
+        self,
+        *,
+        api_key: str | None = None,
+        timeout: float = 8.0,
+    ) -> list[str] | None:
+        """Model listing is handled by the ACP subprocess."""
+        return None
+
+
+kiro_acp = KiroACPProfile(
+    name="kiro-acp",
+    aliases=("kiro", "kiro-cli", "kiro-agent", "kiro-acp-agent"),
+    api_mode="chat_completions",  # ACP subprocess uses chat_completions routing
+    env_vars=(),  # Managed by ACP subprocess
+    base_url="acp://kiro",  # ACP internal scheme
+    auth_type="external_process",
+)
+
+register_provider(kiro_acp)
