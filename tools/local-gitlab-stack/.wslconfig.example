# %UserProfile%\.wslconfig にコピー（Windows ホスト側）。編集後: wsl --shutdown で反映。
# 案A: 個人PC で GitLab CE を動かすためのリソースとネットワーク設定。
[wsl2]
# GitLab CE は実用 8GB。WSL に十分割り当てる（ホストは 16GB+ 推奨）。
memory=12GB
processors=4
swap=4GB

# LAN の他PCから WSL2 内 GitLab へ到達させる方法（どちらか）:
#   (1) Windows 11 22H2+ なら mirrored が最も楽（ホストIPで直接到達）。
#       この行を有効化し、下の setup-network.ps1 は不要になる。
# networkingMode=mirrored
#
#   (2) それ以外は既定(NAT)のまま。setup-network.ps1 で portproxy を貼る。

[experimental]
# mirrored 使用時にホスト⇔WSL のループバックを有効化（任意）
# hostAddressLoopback=true
