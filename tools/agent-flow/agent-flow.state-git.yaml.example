# agent-flow の実構成サンプル — 状態を GitLab に保存・共有する常駐構成
# ファイル名: agent-flow.yaml（このサンプルを丸ごと使う。汎用のキー解説は agent-flow.yaml.example）
#
# 構成: 「daemon 1 台（WSL）＋ gitlab executor で作業を各 PC に分散 ＋ 別 PC の viewer で監視 ＋
#        状態（バスのワーク内容）を GitLab にバックアップ ＋ 同じリポジトリへ他プロセスも push する」
# 対になる agent-project 側の設定 → agent-project.state-git.yaml.example
# （前提の配置・起動手順・他プロセスとの取り決め・閲覧側の組み方はそちらに集約。
#   このファイルは agent-flow 側で一致させるべき値だけを持つ）
#
# ── WSL メモ ──
#   Windows: C:\work\ops\.agents\agent-flow.yaml          ← このファイル（Windows 側クローンで管理）
#   WSL:     ln -s /mnt/c/work/ops/.agents/agent-flow.yaml ~/.agents/agent-flow.yaml
#   読むのは WSL のプロセスなので【パス類は WSL 側のパスで書く】。バスと .state-git クローンは
#   WSL 側ファイルシステム（ext4）に置く（/mnt/c は遅く flock 系ロックも不安定）。
#   起動（WSL）: agent-flow daemon

# --- バス（agent-project 側と同じバスを 1 本に共有。必須）---
# バスが複数あると、複数のバスが同じ state_git_subdir へ同期して互いの run を取り込み合う（混線）。
# 1 本に共有すれば混線が消え、agent-project からの daemon 検知（location=auto/daemon）も効く。
# daemon をプロジェクトルートで起動するなら既定同士（agent-flow ./bus = agent-project <root>/bus）で
# 一致するので指定不要。プロジェクト外に共有バスを置くときだけ両側で同じ絶対パスを明示する:
# bus: /home/me/agent/proj/bus

# --- 実行（作業は GitLab イシューで各 PC へ分散。従来どおり）---
executor: gitlab
gitlab:
  repo_url: https://gitlab.example.com/team/tasks   # 起票先プロジェクト（権威）
  timeout: 0            # 全体タイムアウト無効（0=無限）。人のレビュー往復が数日でも run を失敗にしない。
  approved_timeout: 0   # 承認/決着待ちの猶予も無限。誤タイムアウト由来の retry ループを消す
                        #   （run の本当の失敗は終端ステータスで検知される＝待ち上限は安全網に不要）。
                        #   agent-project 側は act_timeout: 0 ＋ act_async: true と併用する。
  # park & poll（承認待ちを worker スロットから切り離す。既定 有効）。承認待ちのイシューが
  # max_workers を占有せず、監視は daemon が watch_interval 毎にまとめて再確認する。承認待ちが
  # 溜まって発行が止まる問題と多重ポーリングを同時に抑える。従来モード（1 worker=1 イシューで
  # ブロック待機）に戻すなら defer_waits: false。
  # defer_waits: true
  # max_open_issues: 0    # 同時に開ける未決着イシューの上限（0=無制限）。>0 で起票をペーシング
  # watch_interval: 90    # park 済みイシューをまとめて再確認する間隔（秒）
  # close_issues: auto    # イシューのクローズ主体。auto=決着時に executor がクローズ（既定）／
                          #   manual=クローズは人（承認条件が揃うと案内ノートを一度だけ投稿し、
                          #   人がクローズするのを監視して決着。却下クローズは従来どおり executor が行う）。
                          #   別 PC の viewer で最終確認してからクローズしたい運用なら manual。

# --- 状態の git 保存・共有（GitLab バックアップ 兼 別 PC からの監視）---
# agent-project 側と同じリポジトリ・別 subdir。viewer は <clone>/agent-flow をバスとして登録する。
# ★この state_git_subdir が唯一の権威。agent-project に管理させる構成（manage_flow_daemon）でも、
#   この値はこの agent-flow.yaml のパスを flow_config で渡して反映される（agent-project が
#   --state-git-subdir を個別 CLI 注入して上書きすることは無くなった）。変えるなら viewer の
#   flowBusByProject（<clone>/<subdir>）も同じ値に合わせる。
state_git: git@gitlab.example.com:team/agent-state.git
state_git_subdir: agent-flow
# state_git_interval: 300             # fetch/push の最短間隔（秒）。daemon の毎 poll から
#                                     #   呼ばれてもこの間隔でしか GitLab に触れない
#                                     #   （run の終端時だけは間隔を待たず即 push）

# ── バスが同期されない/viewer で見えないときの切り分け ──
# バスを鏡写しするのは【agent-flow daemon の state_sync ループだけ】（agent-project 側の
# state_git はコンテナ状態のみで、バスは同期しない）。上から順に確認する:
#   1. daemon がこの設定を読めているか
#      → daemon 起動ログの2行目に `state-git: 有効 → …（バス … をリモートへ鏡写し）` が出るか。
#        `無効（未設定）` なら agent-flow.yaml が読めていない（--config か 起動 cwd 直下 / .agents/ を確認）。
#        cwd 直下や .agents/ に別の agent-flow.yaml があるとそちらが勝つ点に注意（直下が最優先）。
#   2. クローンとコミットができているか
#      → <bus>/.state-git/ が生成され、そこで `git log` にコミットが増えるか。
#        SSH 鍵など push 認証が WSL 側ユーザーで通ること（手動 `git -C <bus>/.state-git push` で確認）。
#   3. そもそもバスに run があるか
#      → <bus>/runs/ に run-* が出来ているか。無ければ agent-project が daemon を検知できず
#        local 実行に落ちている可能性（agent-project 側で lock_dir / bus 絶対パスの一致を確認）。
#        ※ この構成では local 実行でもバスは消さない（state_git 設定時は _cleanup_bus が保護）。
#   4. viewer 側
#      → 別 PC は <clone>/agent-flow をバスとして登録（clone が git pull で更新され続けているか）。
#        フロータブは meta の生存リースで run の生死を判定する（daemon の pid 判定は同一ホストのみ）。
