# kiro-project の実構成サンプル — 状態を GitLab に保存・共有する常駐構成
# ファイル名: kiro-project.yaml（このサンプルを丸ごと使う。汎用のキー解説は kiro-project.yaml.example）
#
# 構成: 「1 プロジェクト = 1 ディレクトリ = 1 daemon（WSL）＋ gitlab executor で作業を各 PC に分散 ＋
#        別 PC の kiro-projects-viewer で監視・検収 ＋ 状態（ワーク内容）を GitLab にバックアップ」
# 対になる kiro-flow 側の設定 → kiro-flow.state-git.yaml.example
#
# ── 推奨レイアウト（direct モード・state_git 設定不要）──
#   プロジェクトルート自体を GitLab の「状態リポジトリ」の clone にする:
#     git clone git@gitlab.example.com:team/proj-state.git ~/kiro/proj
#     cd ~/kiro/proj && vi charter.md          # 入力（charter / repos.json / policy.md）を書く
#     kiro-project start                       # このディレクトリを常駐監視（run --watch を detached）
#   kiro-project はルートの変更（backlog/needs/decisions/journal/…）をそのままコミットして
#   origin へ push し、viewer 側の commit（指示・検収）を pull で取り込む。
#   一時状態（bus/ claims/）とドット始まりは同期しない。
#   複数プロジェクトは「リポジトリを分けて clone を並べ、各ディレクトリで start する」だけ。
#
# ── 前提の配置（サーバ PC = Windows + WSL）──
#   ★状態の実体（プロジェクトルート / bus）は WSL 側ファイルシステム（ext4）に置く。
#     /mnt/c 配下（DrvFS）は遅く flock 系ロックも不安定なため、常駐の状態置き場にしない。
#   設定ファイルは <root>/kiro-project.yaml（ルート直下＝プロジェクトのマニフェスト。推奨）
#   か <root>/.kiro/kiro-project.yaml か ~/.kiro/ に置く。
#
# ── 起動（WSL・プロジェクトルートで）──
#   kiro-flow daemon &        # 実行層（同じバスで常駐。kiro-flow.state-git.yaml.example を読む）
#   kiro-project start        # 制御層（run --watch を detached 起動）
#   認証: WSL 側ユーザーの SSH 鍵で GitLab へ `git push` が通ること。
#
#   ※ kiro-flow daemon を kiro-project に管理させる構成もある。その場合は
#     manage_flow_daemon: true と flow_config: <kiro-flow.yaml のパス> を設定する。
#     kiro-flow の設定値（executor / state_git_subdir / gitlab.* / defer_waits 等）は
#     kiro-project 側に増やさず、その flow_config（kiro-flow.yaml）へ集約して kiro-flow に読ませる。
#     kiro-project が CLI 注入するのは routing（--state-git の remote/branch/interval）だけで、
#     direct モードならルートの origin が自動で使われる。

# --- 置き場（相対パスはすべて root 基準）---
root: .                              # プロジェクトルート = cwd（状態リポジトリの clone）
workdir: work                        # act / verify の作業ディレクトリ（root 相対 = <root>/work）
# bus: bus                           # 既定は <root>/bus。kiro-flow daemon をプロジェクトルートで
#                                    #   起動すれば既定同士（./bus）で一致する（明示は共有バス時のみ）

# --- 実行（作業そのものは GitLab イシューで各 PC へ分散）---
executor: gitlab
watch: true
act_timeout: 0             # 委譲はレビュー往復で数日かかりうる。0=無制限で完了まで待つ。
                           #   短いタイムアウトだと待ち切れずに retry を空増やし＆イシューを
                           #   二重起票する（この構成では 0 を強く推奨）。
act_async: true            # 非ブロッキング委譲: submit して待たず offloaded にし、次パスでポーリングして
                           #   回収する。長期委譲でループを塞がず、複数タスクを並行に進める。
                           #   併せて kiro-flow 側 gitlab: の timeout/approved_timeout を 0（無限）にすると
                           #   誤タイムアウト由来の retry ループが完全に消える（kiro-flow.state-git.yaml 参照）。

# --- 二段階レビュー（既定すべて on。この構成では明示不要だが、意味は把握しておく）---
# plan_review: true          # 実行前レビュー: 新規タスクは proposed で入り、viewer/needs の承認を
#                             #   通るまで GitLab イシューは起票されない（着手前ゲート）。
# task_branch: true          # 各タスクの成果を kp/<task-id> に集約し、workspace の branch として
#                             #   gitlab executor へ注入する（イシュー本文の「作業ブランチ」に反映され、
#                             #   人/エージェントのワーカーはこのブランチで MR を作る）。
# delivery_review: true      # 成果物レビュー: verify PASS 後に kiro-project 自身が review へ進める
#                             #   （viewer/needs での最終 approve が done の条件）。task_branch の同じ
#                             #   ブランチで MR を探し（無ければ作り＝冪等）、gitlab executor が既に
#                             #   イシュー決着済みなら二重に MR は作らない。approve でクリーンなら
#                             #   Stage 2 と同じ規則で自動マージする。
#                             #   ＝ gitlab のイシュー承認（作業が終わったか）と、この review
#                             #   （成果を受け入れるか）は別ゲート。両方が揃って done になる。
# assess: true               # 投入時アセスメント（既定 on）: 新規タスクを c/r/a（各1-3）で採点し
#                             #   `- assess:` に記録。plan-review 票と検収票のリスクダイジェストに載る
# spec_track: false          # spec ルーティング（既定 off）: 採点が spec_threshold 以上のタスクに
#                             #   spec 前段（specs/<id>/ の spec/design/tasks・review: human）を前置し、
#                             #   spec 承認後に tasks.md を実装タスク群へ展開する。
#                             #   spec タスク自体は委譲されない（location は local 固定・gitlab 等の
#                             #   委譲 executor は agent へ自動差し替え。実装タスクは従来どおり委譲）
# spec_threshold: 3          # spec ルートの採点しきい値（1-3）
# repo_map: false            # リポジトリ理解の成果物化（既定 off）: plan 前に context/<repo名>.md を
#                             #   生成（HEAD sha キャッシュ）。読み出しは常時（手書き context/*.md も注入）

# --- 状態の git 保存・共有 ---
# direct モード（ルートが clone）なら設定不要。ルートが git でない場合のみ管理クローン方式:
# state_git: git@gitlab.example.com:team/kiro-state.git
# state_git_subdir: kiro-project     # kiro-project 自身の名前空間（既定 kiro-project）。
#                                    #   kiro-flow 側の subdir は kiro-flow.yaml の state_git_subdir
#                                    #   （既定 kiro-flow）で別に決まる
# state_git_interval: 300            # fetch/push の最短間隔（秒）。バックアップ粒度を細かく
#                                    #   したければ短く（GitLab への負荷と引き換え）

# --- kiro-flow daemon を kiro-project に管理させる場合 ---
# manage_flow_daemon: true                 # kiro-flow daemon を自動起動・監視
# flow_config: ~/.kiro/kiro-flow.yaml      # kiro-flow の設定（executor/state_git_subdir/gitlab.*/defer_waits 等）
#                                          #   はこのファイルに集約
# flow_max_workers: 6                      # daemon の worker 上限

# ── バックアップと復元 ──
#   バックアップ = 状態リポジトリそのもの（全変更がコミット履歴で残る）。
#   復元 = clone し直してそのディレクトリで start するだけ。
#
# ── 同一リポジトリを他プロセスと共有する取り決め ──
#   ・push 競合は pull --rebase → 再 push（指数バックオフ）で自動吸収し、失敗しても
#     次の同期間隔で再試行（ロックを保持して待ち合わない）
#   ・共有ブランチへの force push は全員禁止（GitLab の保護ブランチで強制推奨）
#   ・viewer の指示（commands/ ドロップ・inbox/ 投入・needs 記入・charter/policy/repos 編集）は
#     同じリポジトリへの commit/push として届く
#   ・ルート内側のドット始まりのファイルと bus/ claims/ は同期・バックアップされない
#
# ── 閲覧側（kiro-projects-viewer）──
#   ・別 PC の viewer: 状態リポジトリを clone し、viewer の ⚙ 設定「プロジェクトのパス」に
#     その clone を 1 行ずつ登録（複数プロジェクト = 複数 clone）。viewer での承認・指示・
#     一時停止/停止は commit/push → 本体が最大 state_git_interval 以内に取り込む
#   ・同じ PC の viewer（Windows）: git を介さず \\wsl$ 直読みでもよい。WSL 側で
#       kiro-project start --registry /mnt/c/Users/me/.kiro-project/instances
#     （または環境変数 KIRO_PROJECT_REGISTRY）にすると、Windows 側 viewer の自動発見が
#     この共有レジストリを拾い、\\wsl$ パスで直接読める
