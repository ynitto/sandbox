# kiro-projects の実構成サンプル — 状態を GitLab に保存・共有する常駐構成
# ファイル名: kiro-projects.yaml（このサンプルを丸ごと使う。汎用のキー解説は kiro-projects.yaml.example）
#
# 構成: 「daemon 1 台（WSL）＋ gitlab executor で作業を各 PC に分散 ＋ 別 PC の viewer で監視 ＋
#        状態（ワーク内容）を GitLab にバックアップ ＋ 同じリポジトリへ他プロセスも push する」
# 対になる kiro-flow 側の設定 → kiro-flow.state-git.yaml.example
#
# ── 前提の配置（サーバ PC = Windows + WSL。設定ファイルは Windows 側クローンで管理）──
#   Windows: C:\work\ops\.kiro\kiro-projects.yaml      ← このファイル（クローンした設定リポジトリ）
#   WSL:     ~/.kiro/kiro-projects.yaml → /mnt/c/work/ops/.kiro/kiro-projects.yaml へのシンボリックリンク
#              ln -s /mnt/c/work/ops/.kiro/kiro-projects.yaml ~/.kiro/kiro-projects.yaml
#            （リンクを張らない場合は起動時に --config /mnt/c/work/ops/.kiro/kiro-projects.yaml を明示）
#   ★設定ファイル自体はどこに置いてもよいが、読むのは WSL のプロセスなので
#     【パス類はすべて WSL 側のパスで書く】。
#   ★状態の実体（root / bus / .state-git クローン）は WSL 側ファイルシステム（ext4）に置く。
#     /mnt/c 配下（DrvFS）は遅く flock 系ロックも不安定なため、常駐の状態置き場にしない。
#
# ── 起動（WSL）──
#   kiro-flow daemon &        # 実行層（同じ共有バスで常駐）
#   kiro-projects start       # 制御層（run --watch --project all を detached 起動）
#   認証: WSL 側ユーザーの SSH 鍵で GitLab へ `git push` が通ること。

# --- 置き場（すべて WSL 側の絶対パス）---
root: /home/me/kiro/.kiro-projects   # コンテナ（状態の実体。GitLab へ同期される側のマスター）
workdir: /home/me/kiro               # act / verify の作業ディレクトリ
bus: /home/me/kiro/.kiro-flow-bus    # ★kiro-flow 側と同じ絶対パスで 1 本に共有（必須）。
                                     #   プロジェクト毎バス（既定）のままだと複数バスが同じ
                                     #   state_git_subdir へ同期して互いの run を取り込み合う。
                                     #   1 本にすれば混線が消え、daemon 検知（location=auto）も
                                     #   全プロジェクトで効く

# --- 実行（作業そのものは GitLab イシューで各 PC へ分散。従来どおり）---
executor: gitlab
watch: true
act_timeout: 0             # 委譲は人のレビュー往復で数日かかりうる。0=無制限で完了まで待つ。
                           #   短いタイムアウトだと待ち切れずに retry を空増やし＆イシューを
                           #   二重起票する（この構成では 0 を強く推奨）。
act_async: true            # 非ブロッキング委譲: submit して待たず offloaded にし、次パスでポーリングして
                           #   回収する。長期委譲でループを塞がず、複数タスク／プロジェクトを並行に進める。
                           #   専用 daemon が run を保持するので、待たなくても結果は取りこぼさない。
                           #   併せて kiro-flow 側 gitlab: の timeout/approved_timeout を 0（無限）にすると
                           #   誤タイムアウト由来の retry ループが完全に消える（kiro-flow.state-git.yaml 参照）。

# --- 状態の git 保存・共有（GitLab バックアップ 兼 別 PC からの監視）---
state_git: git@gitlab.example.com:team/kiro-state.git
# state_git_subdir: kiro-projects    # 既定のまま（kiro-flow 側は kiro-flow）。リポジトリは
#                                    #   kiro-projects/ と kiro-flow/ の 2 名前空間になる。
#                                    #   ドット始まり（.kiro-projects 等）も動作するが、隠し
#                                    #   ディレクトリを見落とすツールがあるため非ドットを推奨
# state_git_interval: 300            # fetch/push の最短間隔（秒）。バックアップ粒度を細かく
#                                    #   したければ短く（GitLab への負荷と引き換え）

# ── バックアップと復元 ──
#   バックアップ = kiro-state リポジトリそのもの（全変更がコミット履歴で残る）。
#   復元 = clone して subdir の中身を新しい root / バスへコピーするだけ
#   （同期スナップショットが無くても、次の同期が裁定規則で決定的に再収束する）。
#
# ── 同一リポジトリを他プロセス（別ディレクトリへ push する別ツール）と共有する取り決め ──
#   この範囲で競合・デッドロックは構造的に起きない:
#   ・kiro は自分専用クローン（<root>/.state-git）だけを使い、ステージも自 subdir のみ
#     → 作業ツリー/index を他プロセスと共有しない。他プロセスも各自のクローンから push する
#       こと（.state-git を共用・改変しない）
#   ・push 競合は pull --rebase → 再 push（指数バックオフ・最大 5 回）で自動吸収し、失敗しても
#     次の同期間隔で再試行（ロックを保持して待ち合わない）
#   ・共有ブランチへの force push は全員禁止（GitLab の保護ブランチで強制推奨）
#   ・他プロセスは kiro の subdir 配下に書かない（viewer の指示ドロップ等の意図した書き込みは可）
#   ・コンテナ/バスの【内側】に置いたドット始まりのファイルは同期・バックアップされない
#     （.swp 等を拾わない仕様）。共有したい手置きファイルは非ドット名にする
#
# ── 閲覧側 ──
#   ・別 PC の viewer: kiro-state を clone（鮮度維持と指示の書き戻しは git-file-sync の
#     bidirectional ペアで常駐同期）し、viewer の ⚙ 設定で
#       コンテナ = <clone>/kiro-projects ／ バス = <clone>/kiro-flow
#     を登録。viewer での承認・フィードバック・タスク投入は commit/push → 本体が最大
#     state_git_interval 以内に取り込む（急ぎの判断は従来どおり GitLab のイシュー/MR 上で）
#   ・同じ PC の viewer（Windows）: state_git を介さず \\wsl$ 直読みでよい。WSL 側で
#       kiro-projects start --registry /mnt/c/Users/me/.kiro-projects/instances
#     （または環境変数 KIRO_PROJECTS_REGISTRY）にすると、Windows 側 viewer の自動発見が
#     この共有レジストリを拾い、\\wsl$ パスで直接読める
