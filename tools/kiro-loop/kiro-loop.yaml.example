# kiro-loop の設定ファイルサンプル
# ファイル名: kiro-loop.yaml
#
# このファイルをどこかに置いて --config で指定するか、
# kiro-loop.py と同じ場所か HOME に置くと自動検出されます。
#
# 検索順序:
#   1. --config オプションで明示指定したパス
#   2. カレントディレクトリの kiro-loop.yaml / .yml / .json
#   3. HOME の kiro-loop.yaml / .yml / .json

# ---------------------------------------------------------------------------
# ワークスペース定義（起動時に自動で kiro-cli セッションを開始する）
# ---------------------------------------------------------------------------
# 省略可。起動後に > add <name> <path> コマンドでも追加できます。
workspaces:
  - name: "project-a"
    path: "~/projects/project-a"
    default: true          # デフォルトワークスペース（prompts の workspace 省略時に使われる）

  - name: "project-b"
    path: "~/projects/project-b"
    # default: false       # 省略時は false

# ---------------------------------------------------------------------------
# kiro-cli の起動オプション（全ワークスペース共通）
# ---------------------------------------------------------------------------
kiro_options:
  trust_all_tools: true    # ツール使用の確認をスキップ（推奨: true）
  resume: false            # 直前のセッションを引き継ぐ
  # agent: my-agent        # エージェントを指定（省略可）
  # model: claude-sonnet   # モデルを指定（省略可）
  # extra_args:
  #   - "--some-option"

# ---------------------------------------------------------------------------
# タイムアウト設定（秒）
# ---------------------------------------------------------------------------
startup_timeout: 60        # kiro-cli 起動待ち上限
response_timeout: 300      # 1 プロンプトの応答待ち上限

# kiro-cli の出力をターミナルに表示するか（stderr に出力される）
echo_output: true

# ---------------------------------------------------------------------------
# 定期プロンプトの定義
# ---------------------------------------------------------------------------
prompts:
  # ---- サンプル 1: project-a で 30 分ごとにコードレビュー ----
  - name: "定期コードレビュー"
    prompt: |
      直近の変更内容を確認して、問題があれば報告してください。
      特にセキュリティ上の懸念点とパフォーマンス上の問題に注目してください。
    interval_minutes: 30
    workspace: "project-a"   # 対象ワークスペース（省略するとデフォルトワークスペースを使う）
    enabled: true

  # ---- サンプル 2: project-b で 60 分ごとにテスト実行 ----
  - name: "定期テスト実行"
    prompt: "テストを実行して結果を教えてください。失敗があれば原因を分析してください。"
    interval_minutes: 60
    workspace: "project-b"
    enabled: true

  # ---- サンプル 3: デフォルトワークスペースで 90 分ごとに TODO チェック ----
  - name: "TODO チェック"
    prompt: |
      プロジェクト内の TODO コメントを確認して、
      優先度が高そうなものをリストアップしてください。
    interval_minutes: 90
    # workspace を省略 → デフォルトワークスペース (project-a) を使う
    enabled: false

  # ---- サンプル 4: 無効化したエントリの例 ----
  - name: "無効なプロンプト"
    prompt: "このプロンプトは実行されません。"
    interval_minutes: 120
    enabled: false
