# review-concierge 設定ファイルサンプル
# このファイルをコピーして review-concierge.yaml という名前で保存してください。
#
# 検索順序:
#   1. --config オプションで明示指定したパス
#   2. カレントディレクトリの review-concierge.yaml / .yml
#   3. HOME の review-concierge.yaml
#
# 接続情報(host/project/token)は gitlab-idd と共有します。
#   - git remote origin から host/project を自動解決
#   - GITLAB_TOKEN 環境変数、または .github/connections.yaml の token を使用
# gl.py が別リポジトリにある場合は GL_SCRIPTS_DIR 環境変数で明示してください。

# ---------------------------------------------------------------------------
# Obsidian Vault（コードリポジトリの外。ここにレビュー成果物を置く）
# ---------------------------------------------------------------------------
vault_path: ~/Documents/Obsidian/MyVault

inbox_dir: "Review/Inbox"        # 判断ノートの出力先（vault 相対）
archive_dir: "Review/Archive"    # 決定済みノートの退避先
queue_file: "Review/Queue.md"    # Dataview 判断キュー

# ---------------------------------------------------------------------------
# 監視対象ラベル（gitlab-idd のラベル規約に合わせる）
# ---------------------------------------------------------------------------
ready_label: "status:review-ready"   # このラベルのイシューを監視
approved_label: "status:approved"    # 承認時に付け替えるラベル
rework_label: "status:rework"        # 差し戻し時に付けるラベル
branch_prefix: "feature/issue-"      # イシュー→MR を引き当てるソースブランチ接頭辞

connection_label: "default"          # connections.yaml のラベル

# ---------------------------------------------------------------------------
# ポーリング（非 LLM。LLM セッション内ポーリングはしない設計）
# ---------------------------------------------------------------------------
poll_interval_sec: 120

# ---------------------------------------------------------------------------
# マージ権限
#   merge_on_approve: true  → 人間が Obsidian で明示承認したノートを writeback する際、
#                             そのまま GitLab MR をマージする（人間の承認＝人間がマージを押した、と扱う）。
#                     false → status:approved 付与＋「マージお願いします」コメントまで。
#                             最終マージは引き続き GitLab 上で人間が押す。
# ---------------------------------------------------------------------------
merge_on_approve: true
squash_on_merge: true
remove_source_branch: true

# ---------------------------------------------------------------------------
# AI レビュー本文の生成（任意・プラガブル）
#   raw バンドル(JSON)を stdin で受け取り、キュレーション済みノート本文(callout 群)を
#   stdout に返すコマンドを指定する。SKILL.md(review-concierge) の指示に従って
#   kiro-cli 等でレビューエージェントを起動するラッパを書くのが想定。
#   未設定なら決定論パケット（受け入れ条件/リスク段階開示/自動チェック）のみ書き出す。
# ---------------------------------------------------------------------------
review_command: ""
# review_command: "kiro-cli --skill review-concierge --stdin-json"

# ---------------------------------------------------------------------------
# リスク・トリアージ（変更ファイルのパスを正規表現で分類。上から順に評価）
#   high → 🔴 必読ゾーンに展開 / low → ⚪ 畳み / それ以外 → 🟡 medium
# ---------------------------------------------------------------------------
risk_rules:
  - level: high
    pattern: "(auth|login|password|secret|token|crypto|payment|billing|migrat|schema|infra|deploy|Dockerfile|\\.tf$|security)"
  - level: low
    pattern: "(test|spec|__tests__|fixtures?|docs?/|\\.md$|README|CHANGELOG|\\.lock$)"
