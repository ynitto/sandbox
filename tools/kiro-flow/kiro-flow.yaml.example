# kiro-flow の設定ファイルサンプル
# ファイル名: kiro-flow.yaml
#
# このファイルをどこかに置いて --config で指定するか、
# カレントディレクトリ（=プロジェクトルート）直下・./.kiro/・~/.kiro/ に置くと自動検出されます。
#
# 検索順序（フォールバック）:
#   1. --config オプションで明示指定したパス
#   2. カレントディレクトリの kiro-flow.yaml / .yml / .json（1 root = 1 プロジェクトのマニフェスト）
#   3. カレントディレクトリの .kiro/kiro-flow.yaml / .yml / .json
#   4. ~/.kiro/kiro-flow.yaml / .yml / .json
#
# 値の優先順位: コマンドライン引数 > この設定ファイル > 組み込み既定。
# つまり「環境ごとに決まる値」をここに書き、その場限りの上書きだけ CLI で渡せます。
#
# PyYAML が無い環境では JSON 形式（kiro-flow.json）にしてください（同じキー）。

# ---------------------------------------------------------------------------
# バス（メッセージ共有先）
# ---------------------------------------------------------------------------
bus: ./bus                 # ローカルバスのルート（cwd 相対、既定 ./bus）。kiro-project の既定
                           #   <root>/bus と同じ場所を指すので、プロジェクトルートで daemon を
                           #   起動すれば設定なしで両者が一致する。git モードでは各ノードの
                           #   クローン親ディレクトリ

# 複数 PC 分散にする場合は共有 git リポジトリを指定（コメントアウトを外す）
# git: git@example.com:team/flow-bus.git
# git_branch: main         # バスに使う git ブランチ（既定 main）
# git_subdir: flow         # リポジトリ内でバスにするサブディレクトリ（既定: リポジトリ直下）。
#                          # 既存リポジトリの一角を間借りする場合に指定する。
#                          # clone/pull/push は sparse checkout で、このサブツリーだけを
#                          # 作業ツリーに展開する（無関係なファイルを取得しない）。

# lock_dir: /var/run/kiro-flow   # daemon singleton ロックの置き場（既定: $TMPDIR/kiro-flow-locks）。
#                          # 外部で起動した daemon を別ツール（kiro-projects 等）から発見させるには、
#                          # 起動側とプローブ側で同じ値にする。TMPDIR が食い違う構成で明示すると確実。

# ---------------------------------------------------------------------------
# 状態の git 保存・共有（state_git）— リモートの kiro-projects-viewer に進捗/結果を見せる
# ---------------------------------------------------------------------------
# ローカルバスのワーク内容（runs/・inbox/）を共有 git リポジトリへ双方向同期する。
# 上の git:（バス自体を git にして実行を分散する GitBus）とは独立の機能で、
# 「実行はローカルのまま、状態の鏡だけを共有する」——実行は state_git に一切依存しない
# （git: 指定時はバス自体が共有 git なので state_git は無視される）。
# fetch/push は state_git_interval で律速され、push は共有すべきローカルコミットがある
# ときだけ（リモートサーバの負荷を一定に保つ）。同一リポジトリには他プログラムもコミット
# してよい: ステージは state_git_subdir 配下のみ・push 競合は pull --rebase → 再 push で
# 吸収・force push はしない。同時変更は「inbox/（人の投入）はリモート優先・runs/（機械状態）
# はローカル優先」で決定的に裁定。書きかけの *.tmp とバス内側のドット始まりは同期しない。
#
# ★実運用の組み方（WSL 常駐＋gitlab executor 分散＋viewer 監視＋GitLab バックアップ＋
#   他プロセスと同一リポジトリを共有するときの取り決め）は kiro-flow.state-git.yaml.example 参照。
# state_git: git@example.com:team/kiro-state.git   # 共有リポジトリ（URL/パス。未指定で無効）
# state_git_branch: main                # 同期先ブランチ
# state_git_subdir: kiro-flow           # リポジトリ内の保存先サブディレクトリ（名前空間分離）
# state_git_interval: 300               # fetch/push の最短間隔（秒）。0 で毎同期（負荷は増える）

# ---------------------------------------------------------------------------
# 実行バックエンド（環境に kiro-cli があるか等で切替）
# ---------------------------------------------------------------------------
planner: flow-planner      # 計画役: flow-planner（3段パイプライン、既定）/ agent（エージェント CLI に
                           #   1回問い合わせ）/ stub（オフライン検証）
executor: agent            # ワーカーバス: 組み込み agent（エージェント CLI に委譲。agent_cli で
                           #   kiro/claude/copilot を切替）/ stub、または executor プラグイン名
                           #   （例 gitlab。opt-in。下の gitlab: ブロック参照）/ .py への明示パス。
                           #   プラグインは executors/<name>.py（kiro-loop の hooks と同じ流儀）。
# executor_dir: ~/my-executors  # executor プラグイン（<name>.py）の追加検索ディレクトリ（任意）
# agent_cli: kiro          # LLM 実行に使うエージェント CLI: kiro（kiro-cli chat・既定）/
                           #   claude（Claude Code ヘッドレス `claude -p`）/
                           #   copilot（GitHub Copilot CLI `copilot -p`）。planner / executor /
                           #   verify 等、このツールの LLM 呼び出しすべてに効く
# model: claude-sonnet     # エージェント CLI に渡すモデル（省略可）。
                           #   kiro: kiro-cli のモデル名 / claude: sonnet・opus 等 /
                           #   copilot: claude-sonnet-4.5・gpt-5 等（copilot /model の一覧に従う）
# agents:                  # 役割毎のエージェント上書き（yaml 専用）。
#   planner:               #   キー: planner（戦略選定・分解）/ evaluator（継続判断・再計画）/
#     agent_cli: claude    #        worker（全ノード kind の既定）/ 個別 kind（work/generate/
#     model: opus          #        classify/synthesize/verify/filter/judge/reduce/split/map。
#   worker:                #        kind は worker より優先）。
#     model: sonnet        #   値: {agent_cli, model}（どちらか片方でも可）。
#   verify:                #   未指定はグローバル agent_cli / model。子プロセス（orchestrator/
#     model: haiku         #   worker）へは --config 伝搬で同じ設定が届く。
granularity: finest        # タスク分解の細かさ: coarse(現状)/fine(1段細)/finest(2段細・既定)。
                           # 細かいほど小さなタスクに多く分解する（プランナーへの指示＋並列ノード倍率）。
                           # 要求に "x3"/"並列3" の明示があればそれを尊重（倍率を効かせない）。
# exemplar_first: false    # map-reduce の fan-out を「見本先行」にする（既定 false）。true で
                           # 先頭1件(pilot map)を検証ゲートに通してから残りを展開する。同様手順の
                           # 繰り返しで 1 件で手順を固めてから残りを流したいときに。--exemplar-first と同義。

# ---------------------------------------------------------------------------
# 並列・キャパシティ（マシン性能に合わせて調整）
# ---------------------------------------------------------------------------
max_workers: 4             # daemon が同時に走らせる worker の上限（このマシンのキャパ）
max_runs: 8                # daemon が同時に実行する run（orchestrator プロセス）の上限。
                           #   バックログ一括投入（kiro-projects の act_async）や再起動直後の孤児
                           #   一斉再開で「run 数ぶんの orchestrator ＋計画エージェント」が同時に
                           #   立ち上がるのを防ぐ。全ノードが park（承認待ち）の run は枠に数えない
                           #   （gitlab 長期委譲は上限で詰まらない）。超過要求は inbox に残り、
                           #   枠が空いた poll で受理される。0 以下で無制限（従来動作）
workers: 2                 # run（単発実行）で起動する worker 数
max_iterations: 3          # 再計画（evaluator-optimizer）の最大反復回数
max_retries: 3             # サーキットブレーカー: 同一系統（verify=fail の再生成・失敗 retry）の
                           #   作り直しをこの回数で打ち切る。達成不可能な完了条件での無限再タスクを防ぐ
max_resumes: 3             # 孤児 run（owning daemon 消失 = PC シャットダウン/クラッシュ）の自動再開の
                           #   上限。「進捗なしの連続回数」で数え、進捗（新しい results/）があれば数え直す
                           #   ＝毎日シャットダウンされる PC でも長期 run を継続できる。0 以下で無効
argv_limit: 100000         # kiro-cli へ argv で渡すプロンプトの最大バイト数。超過分は一時ファイルへ
                           #   退避し参照渡しにする（依存成果物が大きいときの ARG_MAX 起動失敗を防ぐ）
# kiro_timeout: 600        # kiro-cli 1 呼び出しのタイムアウト秒（0/負で無効化）。ハングした kiro-cli を
                           #   止める唯一の手段。省略時は環境変数 KIRO_FLOW_KIRO_TIMEOUT → 既定 600
# stub_sleep_max: 5        # stub executor の擬似実行スリープ上限秒（既定 1〜5 秒。0 で即時）。
                           #   省略時は環境変数 KIRO_FLOW_STUB_SLEEP_MAX → 既定 5

# ---------------------------------------------------------------------------
# 品質（統合前の検証 gate）
# ---------------------------------------------------------------------------
# review: auto             # auto（既定）: 集約パターン（map-reduce / fan-out-and-synthesize）で
#                          #   検証 gate を自動挿入する（公式 Dynamic Workflows の品質パターンに準拠）。
#                          # true: 常に挿入 / false: 無効化。CLI の --review / --no-review が優先。

# ---------------------------------------------------------------------------
# タイミング
# ---------------------------------------------------------------------------
poll: 2.0                  # ポーリング間隔（秒）。git バスは大きめ、ローカルは小さめが目安
lease: 1800                # claim のリース秒数。実タスク時間より十分大きく
                           # （実行中はハートビートが自動延長する）

# ---------------------------------------------------------------------------
# 一時ファイルの自動クリーンアップ（daemon が定期実行）
# ---------------------------------------------------------------------------
# daemon は run 本体（gc が掃除）とは別に、バス外の一時ファイルを定期的に掃除する:
#   - $TMPDIR/kiro-flow-locks/ の未使用ロック（lease の 2 倍以上アイドルで未保持のもの）
#   - <path>.tmp.<pid> の中間ファイル残骸（プロセス crash 由来）
#   - git モードのノード別クローン（run 終了後に孤立し、cleanup_age 時間アイドルのもの）
#   - ワークスペースの孤立 temp clone（$TMPDIR/kiro-flow-ws-<pid>-…。SIGKILL/OOM 等で
#     finally が走らず残ったもの。所有 pid の死亡＋cleanup_age 経過で回収）
cleanup_interval: 3600     # 掃除の実行間隔（秒）。0 以下で無効化（--no-cleanup 相当）
cleanup_age: 24            # 孤立クローンを掃除するまでのアイドル時間（時間）

# 各コマンド（run/work/orchestrate/daemon など）が作る sparse-checkout クローンを、
# 作業後（プロセス終了時）に丸ごと削除する。クローンの溜まり込みを防ぐ既定の挙動。
# false にすると次回起動で再利用するため残す（フル再クローンを避け高速化）。
# CLI では --keep-clone で false 相当（作業後も残す）。
cleanup_clone: true

# ワークスペース（--workspace）の clone を「各ノード完了/失敗ごと」に即削除する。既定は worker
# プロセス終了時に一括削除。長命 worker（--keep-alive）でディスク積み上がりを抑えたいとき true。
# trade-off: 同じワークスペースを次ノードで再 clone するコスト。CLI では --cleanup-per-node。
cleanup_per_node: false

# 書込先ワークスペースは run（=バックログ単位）ごとに 1 つ。CLI/submit に --workspace で渡す
# （素の URL か JSON {url,path,base,target}）。設定ファイルには置かない（run 毎に変わるため）。
# 省略時は読み取り専用 run（commit/push しない）。参照だけのリポジトリは --reference（複数可・読むだけ）
# で渡す（エージェントのプロンプトと gitlab イシューの参照節に描画され、clone はしない）。

# ---------------------------------------------------------------------------
# gitlab ワーカーバス（opt-in / executor プラグイン executors/gitlab.py）
# ---------------------------------------------------------------------------
# executor: gitlab を選んだときだけ使われる委譲バス。この gitlab: ブロックは JSON 化され
# 環境変数 KIRO_FLOW_EXECUTOR_CONFIG でプラグインへ渡される。各ワーカータスクを GitLab
# イシュー化し、リモートの（別マシン/別人の）ワーカーが拾って実装する。kiro-flow は
# イシューをポーリングし、レビュアーが status:approved を付与したら**クリーンな関連 MR
# （コンフリクト無し・未解決レビューコメント無し）を自動マージしてイシューをクローズ**する
# （auto_merge・既定 on。gitlab-review-viewer の承認ボタンと同じ規則。approved なのに
# 未クリーンなら `# 差し戻し` コメント＋status:needs-rework で修正ループへ戻す）。
# GitLab は作業履歴（Merged MR ＋ closed イシュー）の台帳として残る。
# ローカルに kiro-cli が無くても GitLab 越しに作業を委譲できる。
# ★自動マージには api スコープのトークンが必要（read 系のみだとマージ 403 → 人のマージ待ちに落ちる）。
#
# イシュー API は GitLab REST API（v4）を stdlib だけで直叩きする（外部 gl.py 不要・
# フォールバックもしない）。
#
# 起票先 URL は **その run のワークスペース URL（--workspace）を優先**し、無ければ下の repo_url を
# 使う。git remote origin へ曖昧にフォールバックしない（誤ったプロジェクトへの起票を防ぐ）。
# SSH 形（git@host:group/repo.git）と https 形のどちらの URL でも host/project を解釈する。
#
# トークンは kiro-flow.yaml には置かない。gl.py と同じ場所から解決する（優先順）:
#   1. connections.yaml の gitlab/<conn_label> の token（.github/skills 配下 or ~/ のスキルホーム）
#   2. 環境変数 GITLAB_TOKEN / GL_TOKEN
#   3. シェル rc ファイル（~/.bashrc / ~/.bash_profile / ~/.profile / ~/.zshrc）
#
# gitlab:
#   conn_label: default                  # connections.yaml の接続ラベル（トークン解決に使用）
#   repo_url: "https://gitlab.com/group/repo"  # 起票先プロジェクト URL（--workspace 無しのときの
#                                        # フォールバック。ワークスペース URL があればそちらを優先）
#   labels: "status:open,assignee:any"   # 起票するイシューの初期ラベル
#   priority: "priority:normal"          # 付与する優先度ラベル（空文字 "" で付けない）
#   poll_interval: 300                   # イシュー1件の最短再確認間隔（秒）。レビューは遅延しうる
#                                        # 前提で即応性は求めない（十分待つ）
#   # 完了＝approved のクリーンな MR を自動マージ＝イシュークローズ。
#   # レビューの往復は時間がかかるため待機は長め・設定可能（いずれも 0/負で無限）。
#   # ★誤タイムアウト由来の retry ループ／イシュー二重起票を完全に避けたいなら 0（無限）にする。
#   #   run の本当の失敗（却下・orchestrator 異常）は終端ステータスで検知されるので、待ち上限を
#   #   安全網にする必要はない（kiro-project 側 act_timeout: 0 / act_async: true と併用推奨）。
#   timeout: 604800                      # クローズに達するまでの全体上限（秒・既定 7 日。0=無限）
#   approved_timeout: 1209600            # approved/done 検知後のレビュー決着猶予（秒・既定 14 日。0=無限）
#   approved_label: "status:approved"    # このラベルで自動マージ判定に入る（= 受け入れ承認）
#   done_label: "status:done"            # approved 以外に完了とみなすラベル
#   auto_merge: true                     # 自動承認: approved＋クリーンな MR を自動マージ・クローズ。
#                                        # false で従来の「人が関連 MR を管理（マージ/クローズ）」モード
#   close_issues: auto                   # イシューのクローズ主体。auto=決着時に executor がクローズ（既定）／
#                                        # manual=クローズは人（承認条件が揃うと案内ノートを一度だけ投稿し、
#                                        # 人がイシューをクローズするのを監視して決着。却下クローズは従来どおり）
#   rework_label: "status:needs-rework"  # 差し戻し時に approved から付け替えるラベル
#   # --- park & poll（承認待ちを worker スロットから切り離す）---
#   # daemon/run が起票したイシューの決着を待つとき、worker をブロックし続ける代わりにノードを
#   # 「park（保留）」して claim を解放する（worker スロットが空く）。承認待ちは監視主体（daemon/
#   # run）が service_waits で watch_interval 毎に **まとめて** 再確認し、決着したら結果を書く。
#   # これで「承認待ちが max_workers を食い潰して発行が止まる」問題と「N プロセスが各自 30 秒毎に
#   # GitLab を叩く多重ポーリング」を同時に解消する。max_workers は小さいまま据え置ける。
#   defer_waits: true                    # park & poll の ON/OFF。false で従来モード（worker が
#                                        # イシューを監視してブロック待機。1 worker=1 イシュー）に戻す。
#                                        # 承認待ちが max_workers を占有するが挙動が単純。既定 true。
#   watch_interval: 90                   # park 済みイシューをまとめて再確認する間隔（秒。defer_waits=true のみ）
#   # 同時に開ける未決着イシューの上限（0=無制限）。上限に達したら**起票を一時停止**する
#   # （バックプレッシャ＝エラーにはしない。人がレビューを捌いて枠が空けば自動で起票再開）。
#   # 人のレビュー速度に発行をペーシングし、PC/GitLab サーバ負荷を抑えるための蛇口。
#   max_open_issues: 0
#   # --- 人/エージェント判別（gitlab-idd 実行前提）: 人コメントのみを還元へ運ぶ ---
#   # gitlab-idd の worker/reviewer/requester はイシューに大量の自動コメント（着手・scout・設計記録・
#   # clarification 等）を投稿する。フィードバック還元（kiro-projects の learn）に載せるのは**人のコメント
#   # だけ**にする。判別は多層: 全 gitlab-idd マーカー除外・bot 名/フラグ除外・per-issue でマーカー著者を
#   # 学習してその無署名コメントも除外。手で明示したいときだけ以下を指定する。
#   agent_authors: ""                    # エージェント/ボットのアカウント（username か id・カンマ区切り）を除外
#   human_reviewers: ""                  # 人間レビュアーの allowlist（指定するとそれ以外を除外・最も厳密）
#   trust_unmarked_comments: false       # 著者不明の曖昧コメントも拾うか（既定 false＝precision 優先＝無暗に拾わない）
#   # 途中の差し戻し: 人コメントの**見出し**にこの語があれば、承認/却下の決着を待たず「却下級シグナル」として
#   # 拾い、guidance を流して run の再計画（待機ノード変更/ノード追加）を起こす。空文字で無効。
#   # ※ executor 非依存のコントラクト（decision=rejected+guidance）へ変換するだけ＝本体に gitlab 固有分岐は無い。
#   rework_heading: 差し戻し

# ---------------------------------------------------------------------------
# 自動アップデート（既定 on・6 時間毎・起動直後にも実施）
# ---------------------------------------------------------------------------
# スキルリポジトリ（このツールの配布元）の main ブランチに更新が入ったら、daemon の
# アイドル時（要求も子プロセスも無いとき）に自動で取り込む。【既定で有効】（6 時間ごと・
# 起動直後の最初のアイドルでも 1 回実施し、停止中に入った更新を取りこぼさない）。手順は
# doctor と同じ流儀で決定的: git ls-remote で main の先頭コミットを確認し、適用済みと違えば
# temp 領域へ tools/kiro-flow/ だけを sparse-checkout → install.sh を実行 → 動いていた cwd の
# まま graceful 再起動する（os.execv）。手動なら `kiro-flow update [--check|--now]`。
# 初回チェックは「いま動いている本体を最新」とみなしベースラインを記録するだけ（無更新）。
#
# 更新元 URL は通常は設定不要: install.py が生成する skill-registry.json の
# repositories.origin.url（無ければ install_dir）から自動解決する。別リポジトリを使うときだけ
# update_repo を明示する。止めたいときは update_enabled: false か update_check_interval: 0。
#
# 以下はすべて任意（既定のままで有効）。
# update_enabled: true            # 自動アップデートの ON/OFF（false で完全に止める。既定 on）
# update_check_interval: 21600    # 更新チェック間隔（秒）。既定 6 時間。0 以下で自動チェック無効
# update_repo: ""                 # スキルリポジトリ（git URL/パス）。空なら skill-registry.json から自動解決
# update_branch: main             # 追従するブランチ（空/既定なら registry の branch を採用）
# update_subdir: tools/kiro-flow  # リポジトリ内のこのツールのサブディレクトリ
# update_installer: install.sh    # サブディレクトリ内で実行するインストーラ
