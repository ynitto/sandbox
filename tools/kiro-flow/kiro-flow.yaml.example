# kiro-flow の設定ファイルサンプル
# ファイル名: kiro-flow.yaml
#
# このファイルをどこかに置いて --config で指定するか、
# ./.kiro/ か ~/.kiro/ に置くと自動検出されます。
#
# 検索順序（フォールバック）:
#   1. --config オプションで明示指定したパス
#   2. カレントディレクトリの .kiro/kiro-flow.yaml / .yml / .json
#   3. ~/.kiro/kiro-flow.yaml / .yml / .json
#
# 値の優先順位: コマンドライン引数 > この設定ファイル > 組み込み既定。
# つまり「環境ごとに決まる値」をここに書き、その場限りの上書きだけ CLI で渡せます。
#
# PyYAML が無い環境では JSON 形式（kiro-flow.json）にしてください（同じキー）。

# ---------------------------------------------------------------------------
# バス（メッセージ共有先）
# ---------------------------------------------------------------------------
bus: ./.kiro-flow          # ローカルバスのルート。git モードでは各ノードのクローン親ディレクトリ

# 複数 PC 分散にする場合は共有 git リポジトリを指定（コメントアウトを外す）
# git: git@example.com:team/flow-bus.git
# git_branch: main         # バスに使う git ブランチ（既定 main）
# git_subdir: flow         # リポジトリ内でバスにするサブディレクトリ（既定: リポジトリ直下）。
#                          # 既存リポジトリの一角を間借りする場合に指定する。
#                          # clone/pull/push は sparse checkout で、このサブツリーだけを
#                          # 作業ツリーに展開する（無関係なファイルを取得しない）。

# ---------------------------------------------------------------------------
# 実行バックエンド（環境に kiro-cli があるか等で切替）
# ---------------------------------------------------------------------------
planner: flow-planner      # 計画役: flow-planner（3段パイプライン、既定）/ kiro（kiro-cli）/ stub（オフライン検証）
executor: kiro             # ワーカー・評価役: kiro / stub
# model: claude-sonnet     # kiro-cli に渡すモデル（省略可）

# ---------------------------------------------------------------------------
# 並列・キャパシティ（マシン性能に合わせて調整）
# ---------------------------------------------------------------------------
max_workers: 4             # daemon が同時に走らせる worker の上限（このマシンのキャパ）
workers: 2                 # run（単発実行）で起動する worker 数
max_iterations: 3          # 再計画（evaluator-optimizer）の最大反復回数

# ---------------------------------------------------------------------------
# 品質（統合前の検証 gate）
# ---------------------------------------------------------------------------
# review: auto             # auto（既定）: 集約パターン（map-reduce / fan-out-and-synthesize）で
#                          #   検証 gate を自動挿入する（公式 Dynamic Workflows の品質パターンに準拠）。
#                          # true: 常に挿入 / false: 無効化。CLI の --review / --no-review が優先。

# ---------------------------------------------------------------------------
# タイミング
# ---------------------------------------------------------------------------
poll: 2.0                  # ポーリング間隔（秒）。git バスは大きめ、ローカルは小さめが目安
lease: 1800                # claim のリース秒数。実タスク時間より十分大きく
                           # （実行中はハートビートが自動延長する）

# ---------------------------------------------------------------------------
# 一時ファイルの自動クリーンアップ（daemon が定期実行）
# ---------------------------------------------------------------------------
# daemon は run 本体（gc が掃除）とは別に、バス外の一時ファイルを定期的に掃除する:
#   - $TMPDIR/kiro-flow-locks/ の未使用ロック（lease の 2 倍以上アイドルで未保持のもの）
#   - <path>.tmp.<pid> の中間ファイル残骸（プロセス crash 由来）
#   - git モードのノード別クローン（run 終了後に孤立し、cleanup_age 時間アイドルのもの）
cleanup_interval: 3600     # 掃除の実行間隔（秒）。0 以下で無効化（--no-cleanup 相当）
cleanup_age: 24            # 孤立クローンを掃除するまでのアイドル時間（時間）
